#compdef dipper

_dipper() {
  _arguments -s \
    '1::file to annotate:_files' \
    '--prompt[subtitle shown in the header bar]:string:' \
    '--header[label shown above the line list]:string:' \
    '--groups[comma-separated group names (e.g. bug,note,todo)]:csv:' \
    '--preset[named group preset]:preset:(priorities cr)' \
    '--full[output full annotated file]' \
    '--lines[output selected lines with marks only]' \
    '--summary[output group summary block only]' \
    '--json[output annotations as JSON]' \
    '--output[write output to FILE; bare --output auto-derives path]:output file:_files' \
    '--load[restore session from an annotations file]:annotations file:_files' \
    '--files[annotate unannotated files matching GLOB]:glob pattern:'
}

_dipper "$@"
